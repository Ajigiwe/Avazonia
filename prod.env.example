# AVAZONIA PRODUCTION CONFIGURATION
# Instructions: Fill in your live credentials below.

# --- APP SETTINGS ---
APP_NAME=Avazonia
APP_URL=https://yourdomain.com.gh

# --- DATABASE (CPANEL) ---
# Usually 'localhost' in cPanel
DB_HOST=localhost
DB_NAME=cpaneluser_avazonia
DB_USER=cpaneluser_vader
DB_PASS=your_strong_password
DB_PORT=3306

# --- PAYSTACK (LIVE) ---
# Get these from your Paystack Dashboard (Settings > API keys)
PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY

# --- BUSINESS CONTACT ---
WHATSAPP_NUMBER=233240000000
SITE_EMAIL=hello@yourdomain.com.gh

# --- GMAIL SMTP ---
# Use your existing app password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=avazonia@gmail.com
MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD
MAIL_FROM_EMAIL=hello@yourdomain.com.gh
MAIL_FROM_NAME=Avazonia
MAIL_ENCRYPTION=ssl

# Set to 0 for production to hide debug logs
MAIL_DEBUG=0
